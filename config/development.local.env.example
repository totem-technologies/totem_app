# Copy to config/development.local.env (gitignored) to override individual
# values for your local machine. Only applied for the `development` flavor, so
# it can never leak into staging or production builds. Each key here overrides
# the same key from common.env / development.env.
#
# For a platform-specific override, use config/app/development.local.env or
# config/web/development.local.env instead (also gitignored).
#
# Example:
# API_URL=https://totem.local
