# Environment
ENVIRONMENT=development

# API configuration
MOBILE_API_URL=http://localhost:8000/
# Legacy name referenced in the README. The app currently reads MOBILE_API_URL.
# TOTEM_API_URL=http://localhost:8000/

# Auth configuration
MAGIC_LINK_EXPIRATION_MINUTES=30

# LiveKit
LIVEKIT_URL=wss://totem-d7esbgcp.livekit.cloud

# App metadata
APP_VERSION=1.0.0
BUILD_NUMBER=1

# Security
MAX_PIN_ATTEMPTS=5

# Feature flags
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_ANALYTICS=true

# Web push
VAPID_KEY=

# Observability
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Legal
PRIVACY_POLICY_URL=https://www.totem.org/privacy/
TERMS_OF_SERVICE_URL=https://www.totem.org/tos/
COMMUNITY_GUIDELINES_URL=https://www.totem.org/guidelines/